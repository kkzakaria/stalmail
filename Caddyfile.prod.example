# Caddyfile — domaine réel (HTTPS automatique via ACME). Copier en `Caddyfile` sur le
# serveur et remplacer `mail.getstalmail.com` par ton hostname.
#
# vs le Caddyfile de dev (`localhost { tls internal }`) :
#   - le site est le hostname public → Caddy émet un certificat ACME (Let's Encrypt) ;
#   - GOTCHA : `/.well-known/acme-challenge/*` NE DOIT PAS être proxyé vers Stalwart,
#     sinon Caddy renvoie son propre challenge à Stalwart et l'émission du certif échoue.
#     Le matcher @stalwart exclut donc explicitement ce chemin.
#
# Prérequis DNS : un enregistrement A `mail.getstalmail.com` → IP du serveur, et les
# ports 80 + 443  joignables (ACME HTTP-01 / TLS-ALPN-01).

mail.getstalmail.com {
  # Surface HTTP publique de Stalwart (discovery / JMAP / autoconfig), MAIS jamais
  # le challenge ACME (que Caddy doit répondre lui-même).
  @stalwart {
    path /.well-known/* /jmap /jmap/* /autodiscover/* /mail/config-v1.1.xml
    not path /.well-known/acme-challenge/*
  }
  handle @stalwart {
    reverse_proxy stalwart:8080
  }

  # Webmail + wizard de setup.
  handle {
    reverse_proxy app:3000
  }
}
