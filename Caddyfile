# Ingress public Stalmail. Caddy termine le TLS sur :443 et route :
#   - surface HTTP publique de Stalwart (discovery / JMAP / autoconfig) -> stalwart:8080
#   - tout le reste (webmail + wizard de setup)                          -> app:3000
#
# UN SEUL Caddyfile pour dev ET prod, via la variable d'env STALMAIL_HOSTNAME :
#   - non définie (dev / smoke) -> hostname = `localhost` (cert local auto par Caddy)
#   - définie (prod)            -> hostname réel, HTTPS automatique via ACME
#
# Le site fallback `:443` (tls internal, auto-signé) sert le wizard via l'IP du serveur
# AVANT l'existence du DNS : le wizard publie ensuite l'A record + le reste de la zone,
# puis le site nommé obtient son certificat ACME. Caddy gère :80 automatiquement
# (challenges ACME HTTP-01 + redirection vers HTTPS).

# Routes communes aux deux sites (DRY).
(stalmail_routes) {
	# Surface Stalwart publique, MAIS jamais le challenge ACME (Caddy y répond lui-même).
	@stalwart {
		path /.well-known/* /jmap /jmap/* /autodiscover/* /mail/config-v1.1.xml
		not path /.well-known/acme-challenge/*
	}
	handle @stalwart {
		reverse_proxy stalwart:8080
	}
	handle {
		reverse_proxy app:3000
	}
}

# Fallback : accès via IP / hôte non nommé (bootstrap pré-DNS), certificat auto-signé.
:443 {
	tls internal
	import stalmail_routes
}

# Site nommé : domaine réel en prod (ACME), `localhost` en dev (cert local auto).
{$STALMAIL_HOSTNAME:localhost} {
	import stalmail_routes
}
