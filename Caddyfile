# Public ingress for Stalmail. Caddy terminates TLS on 443 and routes:
#   - Stalwart's public HTTP surface (discovery/federation) -> the stalwart service
#   - everything else (webmail + setup wizard)              -> the app service
# tls internal = self-signed local CA cert (dev / pre-domain).
# Replace the site address with your real hostname for automatic ACME HTTPS.
# The app & stalwart services are NOT published directly; only this proxy is.
{
  # Ensures Caddy issues a cert for bare-IP/no-SNI connections (dev/smoke-test).
  default_sni localhost
}

localhost {
  tls internal

  # ACME NOTE: when switching from `tls internal` to automatic HTTPS for a real domain,
  # exclude /.well-known/acme-challenge/* from this matcher BEFORE enabling ACME.
  # If that path is matched here, Caddy proxies its own ACME challenge to Stalwart and
  # certificate issuance fails. Add a preceding handle like:
  #   handle /.well-known/acme-challenge/* { /* let Caddy answer this itself */ }
  # or tighten @stalwart to exclude acme-challenge explicitly. `tls internal` issues no
  # challenge today so this is documentation-only — the routing is intentionally unchanged.
  @stalwart path /.well-known/* /jmap /jmap/* /autodiscover/* /mail/config-v1.1.xml
  handle @stalwart {
    reverse_proxy stalwart:8080
  }

  handle {
    reverse_proxy app:3000
  }
}

:80 {
  redir https://{host}{uri} 308
}
