# Stalmail — variables d'environnement de déploiement (généré par install.sh).
# Copie en .env (chmod 600). Lu par compose.yml / compose.prod.yml.

# Secret de session + mot de passe du recovery admin Stalwart (≥ 64 caractères aléatoires).
# Générer : LC_ALL=C tr -dc 'A-Za-z0-9' < /dev/urandom | head -c 64; echo
STALMAIL_SECRET=remplace-moi-par-64-caracteres-aleatoires

# Hostname public du webmail (sans schéma). Site nommé ACME de Caddy.
STALMAIL_HOSTNAME=mail.getstalmail.com

# URL publique du webmail (https + hostname). Doit correspondre à STALMAIL_HOSTNAME.
STALMAIL_PUBLIC_URL=https://mail.getstalmail.com

# Hash SHA-256 (hex 64 chars) du jeton de setup à usage unique.
# Le jeton en clair n'est jamais stocké — il est uniquement imprimé dans l'URL de fin
# d'install.sh (fragment #token=…). Le wizard vérifie ce hash côté serveur.
# Généré automatiquement par install.sh. Pour regénérer manuellement :
#   TOKEN=$(openssl rand -hex 24)
#   HASH=$(printf '%s' "$TOKEN" | openssl dgst -sha256 | awk '{print $NF}')
#   # Remplacer la valeur ci-dessous, redémarrer app, ouvrir /setup#token=$TOKEN
STALMAIL_SETUP_TOKEN_HASH=remplace-moi-par-le-sha256-hex-du-jeton-de-setup
